# vim: ft=i3config

for_window [class="^Nitrogen$"] floating enable
for_window [class="^Nitrogen$"] resize set 1720 1200
for_window [class="^Nitrogen$"] move position center

for_window [class="^Lxappearance$"] floating enable
for_window [class="^Lxappearance$"] resize set 1720 1200
for_window [class="^Lxappearance$"] move position center
